function drawWheel(angle){
  const cv=document.getElementById('wcanvas'),cx=cv.getContext('2d');
  const sz=Math.min(300,window.innerWidth-60);
  cv.width=sz;cv.height=sz;
  const R=sz/2-6,cx2=sz/2,cy2=sz/2,n=players.length,arc=2*Math.PI/n;
  cx.clearRect(0,0,sz,sz);
  cx.save();cx.shadowBlur=24;cx.shadowColor='rgba(185,79,255,0.5)';
  cx.beginPath();cx.arc(cx2,cy2,R+4,0,2*Math.PI);cx.strokeStyle='rgba(185,79,255,0.3)';cx.lineWidth=3;cx.stroke();cx.restore();
  players.forEach((p,i)=>{
    const s=angle+i*arc,e=s+arc;
    cx.beginPath();cx.moveTo(cx2,cy2);cx.arc(cx2,cy2,R,s,e);cx.closePath();
    cx.fillStyle=neonCols[i%neonCols.length]+'22';cx.fill();
    cx.strokeStyle=neonCols[i%neonCols.length];cx.lineWidth=2;cx.stroke();
    const mid=s+arc/2,tx=cx2+Math.cos(mid)*(R*0.65),ty=cy2+Math.sin(mid)*(R*0.65);
    cx.save();cx.translate(tx,ty);cx.rotate(mid+Math.PI/2);
    cx.fillStyle=neonCols[i%neonCols.length];
    cx.font=`bold ${Math.max(11,sz/players.length/3)}px Outfit`;
    cx.textAlign='center';cx.textBaseline='middle';
    cx.shadowBlur=8;cx.shadowColor=neonCols[i%neonCols.length];
    cx.fillText(p.slice(0,8),0,0);cx.restore();
  });
  cx.beginPath();cx.arc(cx2,cy2,20,0,2*Math.PI);cx.fillStyle='#0d0d1f';cx.fill();cx.strokeStyle='#b94fff';cx.lineWidth=2;cx.stroke();
  cx.beginPath();cx.moveTo(cx2,4);cx.lineTo(cx2-10,22);cx.lineTo(cx2+10,22);cx.closePath();
  cx.fillStyle='#ffe03a';cx.shadowBlur=12;cx.shadowColor='#ffe03a';cx.fill();
}
function spinWheel(){
  if(wheelSpinning)return;
  wheelSpinning=true;
  document.getElementById('spin-btn').disabled=true;
  document.getElementById('spin-result').textContent='Spinning...';
  const extra=Math.PI*2*(5+Math.random()*6);
  const from=wheelAngle,dur=3200+Math.random()*1400,start=performance.now();
  let prevSeg=-1;
  function frame(now){
    const t=Math.min(1,(now-start)/dur),ease=1-Math.pow(1-t,4);
    wheelAngle=from+extra*ease;
    // tick sound on segment change
    const n=players.length,arc=2*Math.PI/n;
    const norm=((Math.PI*2.5-wheelAngle)%(Math.PI*2)+Math.PI*2)%(Math.PI*2);
    const seg=Math.floor(norm/arc)%n;
    if(seg!==prevSeg){playTick();prevSeg=seg;}
    drawWheel(wheelAngle);
    if(t<1){requestAnimationFrame(frame);}
    else{
      wheelAngle=wheelAngle%(Math.PI*2);
      const norm2=((Math.PI*2.5-wheelAngle)%(Math.PI*2)+Math.PI*2)%(Math.PI*2);
      curIdx=Math.floor(norm2/arc)%n;
      document.getElementById('spin-result').textContent=`🎉 ${players[curIdx]}!`;
      playWin();
      wheelSpinning=false;
      setTimeout(()=>{document.getElementById('s-wheel').style.display='none';showTurn();},1300);
    }
  }
  requestAnimationFrame(frame);
}

