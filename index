  document.getElementById('round-lbl').textContent=`Round ${round}`;
  document.getElementById('ppills').innerHTML=players.map((p,i)=>`<span class="ppill ${i===curIdx?'active':''}">${p}</span>`).join('');
  document.getElementById('turn-name').textContent=players[curIdx];
  document.getElementById('tod-row').style.display='grid';
  document.getElementById('card-area').innerHTML='';
  document.getElementById('skip-txt').textContent=`Skips left: ${skips[players[curIdx]]}`;
}

function buildPool(type){
  let pool=[];
  selCats.forEach(cat=>{
    if(!QDB[cat])return;
    selContent.forEach(content=>{
      const lvl={family:'family',mild:'mild',adult:'adult',personal:'personal',political:'mild'}[content]||content;
      if(QDB[cat][lvl]&&QDB[cat][lvl][type]){
        QDB[cat][lvl][type].forEach((q,i)=>{
          const id=`${cat}-${lvl}-${type}-${i}`;
          if(!usedIds.has(id))pool.push({text:q,cat:cat.toUpperCase().replace('WOULDYOU','WOULD YOU RATHER').replace('HOTTAKES','HOT TAKES'),id});
        });
      }
    });
  });
  customQs.filter(q=>q.type===type).forEach((q,i)=>{
    const id=`cq-${type}-${i}`;
    if(!usedIds.has(id))pool.push({text:q.text,cat:q.cat.toUpperCase(),id});
  });
  return pool;
}

function pick(type){
  if(type==='truth')playTruth();else playDare();
  let pool=buildPool(type);
  if(!pool.length){usedIds=new Set();pool=buildPool(type);}
  if(!pool.length){document.getElementById('card-area').innerHTML='<p style="color:var(--dim);text-align:center;padding:20px;letter-spacing:2px;font-size:13px;">No questions match! Enable more categories.</p>';return;}
  const q=pool[Math.floor(Math.random()*pool.length)];
  usedIds.add(q.id);
  const it=type==='truth';
  document.getElementById('tod-row').style.display='none';
  setTimeout(()=>{playFlip();},150);
  document.getElementById('card-area').innerHTML=`
    <div class="q-card q-card-${type}">
      <span class="q-badge ${it?'badge-truth':'badge-dare'}">${type.toUpperCase()}</span>
      <div class="q-cat">${q.cat}</div>
      <div class="q-text">${q.text}</div>
    </div>
    <div class="action-row">
      <button class="btn btn-next" onclick="nextPlayer()">Done ✓</button>
      <button class="btn btn-punish" onclick="showPunishment()">😈 Refused!</button>
      <button class="btn btn-skip2" onclick="doSkip('${type}')">Skip (${skips[players[curIdx]]})</button>
    </div>`;
  document.getElementById('skip-txt').textContent='';
}

function showPunishment(){
  playLoser();
  const msg=SARCASM[Math.floor(Math.random()*SARCASM.length)];
  const t=document.getElementById('sarcast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3200);
  const p=PUNISHMENTS[Math.floor(Math.random()*PUNISHMENTS.length)];
  document.getElementById('card-area').innerHTML=`
    <div class="q-card q-card-punish">
      <span class="q-badge badge-punish">😈 PUNISHMENT</span>
      <div class="q-cat">${p.cat}</div>
      <div class="q-text">${p.text}</div>
    </div>
    <div class="action-row">
      <button class="btn btn-next" onclick="nextPlayer()">Done & Next ✓</button>
      <button class="btn btn-punish" onclick="showPunishment()">Different One 🎲</button>
    </div>`;
}

function doSkip(type){
  const p=players[curIdx];
  if(skips[p]<=0){document.getElementById('skip-txt').textContent='No skips left! Face it or get punished 😈';return;}
  skips[p]--;pick(type);
}

function nextPlayer(){
  playWin();confetti();
  curIdx++;
  if(curIdx>=players.length){curIdx=0;round++;}
  gameMode==='wheel'?showWheel():showTurn();
}

function endGame(){
  document.getElementById('s-wheel').style.display='none';
  document.getElementById('s-game').style.display='none';
  document.getElementById('s-end').style.display='block';
  confetti();playWin();
}
function resetAll(){
  document.getElementById('s-end').style.display='none';
  document.getElementById('s-setup').style.display='block';
  initSetup();
}

function confetti(){
  const cv=document.getElementById('cc'),cx=cv.getContext('2d');
  cv.width=window.innerWidth;cv.height=window.innerHeight;
  const cols=['#ff2d78','#00f0ff','#b94fff','#ffe03a','#00ffaa','#ff8800'];
  const pts=Array.from({length:90},()=>({x:Math.random()*cv.width,y:-16,vx:(Math.random()-.5)*5,vy:Math.random()*4+2,w:Math.random()*10+4,h:Math.random()*5+3,col:cols[Math.floor(Math.random()*cols.length)],rot:Math.random()*360,rv:(Math.random()-.5)*12,life:1}));
  let f=0;
  (function draw(){
    cx.clearRect(0,0,cv.width,cv.height);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.rot+=p.rv;p.life-=0.01;cx.save();cx.globalAlpha=Math.max(0,p.life);cx.translate(p.x,p.y);cx.rotate(p.rot*Math.PI/180);cx.fillStyle=p.col;cx.fillRect(-p.w/2,-p.h/2,p.w,p.h);cx.restore();});
    if(++f<160)requestAnimationFrame(draw);else cx.clearRect(0,0,cv.width,cv.height);
  })();
}

initSetup();
</script>
