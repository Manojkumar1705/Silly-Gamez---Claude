<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{--bg:#07070f;--panel:#0d0d1f;--border:#ffffff18;--pink:#ff2d78;--cyan:#00f0ff;--purple:#b94fff;--yellow:#ffe03a;--green:#00ffaa;--orange:#ff8800;--dim:#ffffff55;--text:#f0f0ff;}
body{background:var(--bg);font-family:'Outfit',sans-serif;color:var(--text);min-height:100vh;overflow-x:hidden;}
.bg-fx{position:fixed;inset:0;pointer-events:none;z-index:0;}
.bg-fx::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 50% at 20% 20%,rgba(185,79,255,0.13) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 80%,rgba(255,45,120,0.11) 0%,transparent 60%),radial-gradient(ellipse 50% 60% at 50% 50%,rgba(0,240,255,0.07) 0%,transparent 70%);animation:bgp 6s ease-in-out infinite alternate;}
@keyframes bgp{from{opacity:.7}to{opacity:1}}
.bg-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:40px 40px;}
.wrap{position:relative;z-index:1;max-width:720px;margin:0 auto;padding:14px 14px 40px;}
.club-logo{font-family:'Bebas Neue',sans-serif;font-size:clamp(34px,8vw,66px);letter-spacing:5px;text-align:center;background:linear-gradient(135deg,var(--pink),var(--purple),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 18px rgba(255,45,120,.5));animation:lg 3s ease-in-out infinite alternate;padding:22px 0 4px;}
@keyframes lg{from{filter:drop-shadow(0 0 10px rgba(255,45,120,.4))}to{filter:drop-shadow(0 0 26px rgba(0,240,255,.6))}}
.club-sub{font-size:11px;letter-spacing:8px;color:var(--dim);text-transform:uppercase;text-align:center;margin-bottom:6px;}
/* sound toggle */
.sound-bar{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:18px;}
.sound-toggle{background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:20px;padding:6px 16px;cursor:pointer;font-size:12px;font-weight:600;letter-spacing:2px;color:var(--dim);transition:all .2s;display:flex;align-items:center;gap:6px;}
.sound-toggle.on{border-color:var(--green);color:var(--green);background:rgba(0,255,170,.08);box-shadow:0 0 12px rgba(0,255,170,.2);}
.vol-hint{font-size:11px;color:var(--dim);letter-spacing:1px;}
.glass{background:rgba(13,13,31,.88);border:1px solid var(--border);border-radius:20px;padding:20px;margin-bottom:14px;backdrop-filter:blur(12px);position:relative;overflow:hidden;}
.glass::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:5px;color:var(--dim);text-transform:uppercase;margin-bottom:13px;}
.player-row{display:flex;gap:8px;align-items:center;margin-bottom:8px;}
.pav{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:14px;flex-shrink:0;}
.ni{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'Outfit',sans-serif;font-size:15px;font-weight:600;padding:9px 14px;flex:1;outline:none;letter-spacing:1px;transition:border-color .25s,box-shadow .25s;}
.ni:focus{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(0,240,255,.12);}
.ni::placeholder{color:rgba(255,255,255,.2);font-weight:300;}
.del-btn{background:none;border:1px solid rgba(255,45,120,.3);color:var(--pink);border-radius:8px;width:32px;height:32px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;}
.del-btn:hover{background:rgba(255,45,120,.15);border-color:var(--pink);}
.add-p{width:100%;padding:10px;background:rgba(255,255,255,.03);border:1px dashed rgba(255,255,255,.12);border-radius:10px;color:var(--dim);font-family:'Outfit',sans-serif;font-size:14px;cursor:pointer;transition:all .2s;letter-spacing:2px;margin-top:4px;}
.add-p:hover{border-color:var(--purple);color:var(--purple);}
.chip-row{display:flex;flex-wrap:wrap;gap:8px;}
.chip{padding:7px 14px;border-radius:30px;border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.4);font-size:11px;font-weight:600;letter-spacing:1.5px;cursor:pointer;transition:all .2s;text-transform:uppercase;background:transparent;user-select:none;}
.chip:hover{border-color:rgba(255,255,255,.3);color:rgba(255,255,255,.7);}
.chip.on-p{border-color:var(--pink);color:var(--pink);background:rgba(255,45,120,.12);box-shadow:0 0 10px rgba(255,45,120,.2);}
.chip.on-c{border-color:var(--cyan);color:var(--cyan);background:rgba(0,240,255,.1);}
.chip.on-pu{border-color:var(--purple);color:var(--purple);background:rgba(185,79,255,.12);}
.mode-toggle{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.mode-card{padding:16px;border-radius:14px;border:1px solid var(--border);cursor:pointer;text-align:center;transition:all .25s;background:rgba(255,255,255,.03);}
.mode-card:hover{border-color:rgba(255,255,255,.25);}
.mode-card.sel{border-color:var(--cyan);background:rgba(0,240,255,.08);box-shadow:0 0 18px rgba(0,240,255,.15);}
.mode-icon{font-size:26px;display:block;margin-bottom:6px;}
.mode-name{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;color:var(--cyan);}
.mode-desc{font-size:11px;color:var(--dim);margin-top:3px;}
.btn{font-family:'Outfit',sans-serif;font-weight:700;letter-spacing:2px;font-size:13px;border:none;border-radius:12px;padding:13px 22px;cursor:pointer;transition:all .2s;text-transform:uppercase;}
.btn:active{transform:scale(.97);}
.btn-full{width:100%;display:block;margin-top:10px;}
.btn-start{background:linear-gradient(135deg,var(--pink),var(--purple));color:#fff;font-size:15px;padding:16px;box-shadow:0 4px 24px rgba(255,45,120,.4);letter-spacing:3px;}
.btn-start:hover{box-shadow:0 6px 32px rgba(255,45,120,.6);transform:translateY(-1px);}
.btn-next{background:linear-gradient(135deg,var(--green),#00c6ff);color:#07070f;font-weight:700;box-shadow:0 4px 20px rgba(0,255,170,.3);}
.btn-punish{background:linear-gradient(135deg,var(--orange),var(--yellow));color:#07070f;font-weight:700;box-shadow:0 4px 20px rgba(255,136,0,.35);}
.btn-skip2{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:var(--dim);}
.btn-skip2:hover{border-color:var(--yellow);color:var(--yellow);}
.btn-sm{font-size:11px;padding:8px 14px;border-radius:8px;}
.neon-ta{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'Outfit',sans-serif;font-size:14px;padding:10px 14px;flex:1;min-width:160px;min-height:56px;outline:none;resize:vertical;transition:border-color .25s;}
.neon-ta:focus{border-color:var(--purple);}
.neon-sel{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'Outfit',sans-serif;font-size:13px;padding:9px 12px;outline:none;}
.cq-list{list-style:none;max-height:140px;overflow-y:auto;}
.cq-item{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:13px;color:var(--dim);}
.cq-badge{font-size:9px;font-weight:700;letter-spacing:2px;padding:3px 8px;border-radius:10px;flex-shrink:0;}
.cq-t{background:rgba(0,200,255,.15);color:var(--cyan);}
.cq-d{background:rgba(255,45,120,.15);color:var(--pink);}
.cq-del{background:none;border:none;color:rgba(255,45,120,.4);cursor:pointer;font-size:16px;margin-left:auto;}
.cq-del:hover{color:var(--pink);}
.type-tog{display:flex;border-radius:10px;overflow:hidden;border:1px solid var(--border);flex-shrink:0;}
.tt-btn{flex:1;padding:9px 12px;background:transparent;border:none;color:var(--dim);font-family:'Outfit',sans-serif;font-size:12px;font-weight:600;letter-spacing:1px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.tt-btn.st{background:rgba(0,200,255,.15);color:var(--cyan);}
.tt-btn.sd{background:rgba(255,45,120,.15);color:var(--pink);}
/* wheel */
.wheel-wrap{display:flex;flex-direction:column;align-items:center;gap:14px;padding:10px 0;}
.spin-btn{background:linear-gradient(135deg,var(--pink),var(--purple));color:#fff;font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:4px;padding:14px 40px;border:none;border-radius:40px;cursor:pointer;box-shadow:0 4px 24px rgba(255,45,120,.4);transition:all .2s;}
.spin-btn:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(255,45,120,.6);}
.spin-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.spin-result{font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,5vw,30px);letter-spacing:4px;text-align:center;min-height:38px;background:linear-gradient(135deg,var(--cyan),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
/* game */
.ppill{padding:6px 14px;border-radius:20px;border:1px solid rgba(255,255,255,.1);font-size:12px;font-weight:600;letter-spacing:1px;color:rgba(255,255,255,.35);transition:all .3s;}
.ppill.active{border-color:var(--pink);color:var(--text);background:rgba(255,45,120,.15);box-shadow:0 0 14px rgba(255,45,120,.3);animation:ap 2s ease-in-out infinite;}
@keyframes ap{0%,100%{box-shadow:0 0 10px rgba(255,45,120,.3)}50%{box-shadow:0 0 22px rgba(255,45,120,.6)}}
.turn-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(28px,7vw,48px);letter-spacing:4px;text-align:center;padding:10px 0 14px;background:linear-gradient(90deg,var(--cyan),var(--purple),var(--pink));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tod-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:4px;}
.tod-big{padding:26px 10px;border-radius:16px;font-family:'Bebas Neue',sans-serif;font-size:clamp(20px,5vw,30px);letter-spacing:4px;text-align:center;cursor:pointer;border:none;transition:all .25s;position:relative;overflow:hidden;}
.tod-big::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .2s;background:rgba(255,255,255,.1);}
.tod-big:hover::before{opacity:1;}
.tod-big:active{transform:scale(.97);}
.truth-big{background:linear-gradient(135deg,#0a1a3a,#0d2657);border:1px solid rgba(0,200,255,.4);color:var(--cyan);box-shadow:0 0 24px rgba(0,150,255,.2);}
.dare-big{background:linear-gradient(135deg,#3a0a1a,#570d22);border:1px solid rgba(255,45,120,.4);color:var(--pink);box-shadow:0 0 24px rgba(255,45,120,.2);}
.tod-icon{font-size:26px;display:block;margin-bottom:5px;}
.q-card{border-radius:20px;padding:22px;margin-bottom:12px;position:relative;overflow:hidden;animation:ci .35s cubic-bezier(0.34,1.56,0.64,1);}
@keyframes ci{from{transform:translateY(-18px) scale(.95);opacity:0}to{transform:none;opacity:1}}
.q-card-truth{background:linear-gradient(135deg,rgba(0,50,120,.6),rgba(0,20,60,.8));border:1px solid rgba(0,200,255,.35);box-shadow:0 8px 32px rgba(0,100,255,.15);}
.q-card-dare{background:linear-gradient(135deg,rgba(120,0,50,.6),rgba(60,0,20,.8));border:1px solid rgba(255,45,120,.35);box-shadow:0 8px 32px rgba(255,0,80,.15);}
.q-card-punish{background:linear-gradient(135deg,rgba(120,60,0,.6),rgba(80,30,0,.8));border:1px solid rgba(255,136,0,.45);box-shadow:0 8px 32px rgba(255,136,0,.2);animation:ci .35s cubic-bezier(0.34,1.56,0.64,1);}
.q-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:10px;}
.badge-truth{background:rgba(0,200,255,.15);color:var(--cyan);border:1px solid rgba(0,200,255,.3);}
.badge-dare{background:rgba(255,45,120,.15);color:var(--pink);border:1px solid rgba(255,45,120,.3);}
.badge-punish{background:rgba(255,136,0,.2);color:var(--orange);border:1px solid rgba(255,136,0,.4);}
.q-cat{font-size:11px;letter-spacing:4px;color:var(--dim);text-transform:uppercase;margin-bottom:10px;}
.q-text{font-size:clamp(18px,4vw,24px);font-weight:400;line-height:1.45;color:#fff;letter-spacing:.3px;}
.action-row{display:flex;gap:8px;flex-wrap:wrap;}
.action-row .btn{flex:1;min-width:100px;}
.skip-txt{text-align:center;font-size:12px;color:var(--dim);letter-spacing:2px;margin-top:8px;}
.round-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.round-badge{font-size:11px;font-weight:700;letter-spacing:3px;color:var(--green);text-transform:uppercase;}
.quit-btn{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:var(--dim);font-family:'Outfit',sans-serif;font-size:11px;font-weight:600;letter-spacing:2px;padding:6px 14px;border-radius:8px;cursor:pointer;transition:all .2s;}
.quit-btn:hover{border-color:var(--pink);color:var(--pink);}
/* sarcasm toast */
.sarcast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(30px);background:rgba(10,5,25,.97);border:1px solid var(--orange);border-radius:16px;padding:14px 26px;font-size:17px;font-weight:700;color:var(--orange);letter-spacing:1px;opacity:0;transition:all .4s cubic-bezier(0.34,1.3,0.64,1);pointer-events:none;z-index:9999;text-align:center;backdrop-filter:blur(16px);white-space:nowrap;box-shadow:0 0 30px rgba(255,136,0,.3);}
.sarcast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.end-screen{text-align:center;padding:20px 0;}
.end-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,10vw,70px);letter-spacing:6px;background:linear-gradient(135deg,var(--pink),var(--yellow),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:10px;}
.end-sub{color:var(--dim);letter-spacing:3px;font-size:13px;margin-bottom:24px;}
.divider{border:none;border-top:1px solid rgba(255,255,255,.06);margin:16px 0;}
#cc{position:fixed;inset:0;pointer-events:none;z-index:9998;}
.player-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.av0{background:rgba(255,45,120,.2);color:var(--pink);}
.av1{background:rgba(0,240,255,.15);color:var(--cyan);}
.av2{background:rgba(185,79,255,.2);color:var(--purple);}
.av3{background:rgba(255,224,58,.15);color:var(--yellow);}
.av4{background:rgba(0,255,170,.15);color:var(--green);}
.av5{background:rgba(255,150,30,.15);color:#ff961e;}
.av6{background:rgba(200,100,255,.15);color:#c864ff;}
.av7{background:rgba(100,200,255,.15);color:#64c8ff;}
</style>
</head>
<body>
<canvas id="cc"></canvas>
<div class="bg-fx"><div class="bg-grid"></div></div>
<div class="sarcast" id="sarcast"></div>
<div class="wrap">
  <div class="club-logo">TRUTH OR DARE</div>
  <div class="club-sub">The Party Edition ✦ v3</div>
  <div class="sound-bar">
    <button class="sound-toggle" id="sound-toggle" onclick="toggleSound()">🔇 Sound Off — Tap to Enable</button>
    <span class="vol-hint">🔊 Turn volume up!</span>
  </div>

  <!-- SETUP -->
  <div id="s-setup">
    <div class="glass">
      <div class="sec-title">Who's Playing Tonight?</div>
      <div id="pinputs"></div>
      <button class="add-p" onclick="addPlayer()">+ Add Player</button>
    </div>
    <div class="glass">
      <div class="sec-title">Turn Style</div>
      <div class="mode-toggle">
        <div class="mode-card sel" id="mc-default" onclick="setMode('default')">
          <span class="mode-icon">🎲</span>
          <div class="mode-name">Random</div>
          <div class="mode-desc">Instant random pick</div>
        </div>
        <div class="mode-card" id="mc-wheel" onclick="setMode('wheel')">
          <span class="mode-icon">🌀</span>
          <div class="mode-name">Spin Wheel</div>
          <div class="mode-desc">Spin to choose player</div>
        </div>
      </div>
    </div>
    <div class="glass">
      <div class="sec-title">Content Level</div>
      <div class="chip-row">
        <span class="chip on-c" data-c="family" onclick="togC(this,'on-c')">Family</span>
        <span class="chip" data-c="mild" onclick="togC(this,'on-pu')">Mild 16+</span>
        <span class="chip" data-c="adult" onclick="togC(this,'on-p')">Adult 18+</span>
        <span class="chip" data-c="personal" onclick="togC(this,'on-pu')">Personal</span>
        <span class="chip" data-c="political" onclick="togC(this,'on-c')">Political</span>
      </div>
    </div>
    <div class="glass">
      <div class="sec-title">Categories</div>
      <div class="chip-row">
        <span class="chip on-p" data-cat="gaming" onclick="togCat(this)">🎮 Gaming</span>
        <span class="chip on-p" data-cat="food" onclick="togCat(this)">🍕 Food</span>
        <span class="chip on-p" data-cat="education" onclick="togCat(this)">📚 Education</span>
        <span class="chip on-p" data-cat="travel" onclick="togCat(this)">✈️ Travel</span>
        <span class="chip on-p" data-cat="relationships" onclick="togCat(this)">💬 Relationships</span>
        <span class="chip on-p" data-cat="political" onclick="togCat(this)">🗳️ Political</span>
        <span class="chip on-p" data-cat="fitness" onclick="togCat(this)">💪 Fitness</span>
        <span class="chip on-p" data-cat="popculture" onclick="togCat(this)">🎬 Pop Culture</span>
        <span class="chip on-p" data-cat="embarrassing" onclick="togCat(this)">😳 Embarrassing</span>
        <span class="chip on-p" data-cat="secrets" onclick="togCat(this)">🤫 Secrets</span>
        <span class="chip on-p" data-cat="hottakes" onclick="togCat(this)">🌶️ Hot Takes</span>
        <span class="chip on-p" data-cat="wouldyou" onclick="togCat(this)">🤔 Would You Rather</span>
      </div>
    </div>
    <div class="glass">
      <div class="sec-title">Custom Questions</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;">
        <textarea class="neon-ta" id="cq-in" placeholder="Type your own truth or dare..."></textarea>
        <div style="display:flex;flex-direction:column;gap:8px;flex-shrink:0;">
          <div class="type-tog">
            <button class="tt-btn st" id="ttb" onclick="setCT('truth')">TRUTH</button>
            <button class="tt-btn" id="tdb" onclick="setCT('dare')">DARE</button>
          </div>
          <select class="neon-sel" id="cq-cat">
            <option value="gaming">Gaming</option><option value="food">Food</option>
            <option value="education">Education</option><option value="travel">Travel</option>
            <option value="relationships">Relationships</option><option value="political">Political</option>
            <option value="fitness">Fitness</option><option value="popculture">Pop Culture</option>
            <option value="embarrassing">Embarrassing</option><option value="secrets">Secrets</option>
            <option value="hottakes">Hot Takes</option><option value="wouldyou">Would You Rather</option>
          </select>
          <button class="btn btn-sm" style="background:rgba(185,79,255,.2);border:1px solid rgba(185,79,255,.4);color:var(--purple);font-family:'Outfit',sans-serif;font-weight:700;letter-spacing:2px;" onclick="addCQ()">ADD</button>
        </div>
      </div>
      <ul class="cq-list" id="cq-list"></ul>
    </div>
    <button class="btn btn-start btn-full" onclick="startGame()">Let's Go 🎉</button>
  </div>

  <!-- WHEEL -->
  <div id="s-wheel" style="display:none;">
    <div class="glass">
      <div class="round-row">
        <span class="round-badge" id="w-round-lbl">Round 1</span>
        <button class="quit-btn" onclick="endGame()">End Night</button>
      </div>
      <div class="wheel-wrap">
        <canvas id="wcanvas" width="300" height="300"></canvas>
        <div class="spin-result" id="spin-result">Spin to pick a player!</div>
        <button class="spin-btn" id="spin-btn" onclick="spinWheel()">SPIN 🌀</button>
      </div>
    </div>
  </div>

  <!-- GAME -->
  <div id="s-game" style="display:none;">
    <div class="glass">
      <div class="round-row">
        <span class="round-badge" id="round-lbl">Round 1</span>
        <button class="quit-btn" onclick="endGame()">End Night</button>
      </div>
      <div class="player-pills" id="ppills"></div>
      <div class="turn-name" id="turn-name">PLAYER</div>
      <div class="tod-row" id="tod-row">
        <button class="tod-big truth-big" onclick="pick('truth')"><span class="tod-icon">🤔</span>TRUTH</button>
        <button class="tod-big dare-big" onclick="pick('dare')"><span class="tod-icon">🔥</span>DARE</button>
      </div>
      <div id="card-area"></div>
      <div class="skip-txt" id="skip-txt"></div>
    </div>
  </div>

  <!-- END -->
  <div id="s-end" style="display:none;">
    <div class="glass end-screen">
