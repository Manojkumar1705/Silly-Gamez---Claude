/* ===== WEB AUDIO ENGINE ===== */
let actx = null;
let soundOn = false;

function getCtx() {
  if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
  if (actx.state === 'suspended') actx.resume();
  return actx;
}

function toggleSound() {
  soundOn = !soundOn;
  const btn = document.getElementById('sound-toggle');
  if (soundOn) {
    getCtx();
    btn.textContent = '🔊 Sound On';
    btn.classList.add('on');
    playChime();
  } else {
    btn.textContent = '🔇 Sound Off — Tap to Enable';
    btn.classList.remove('on');
  }
}

// Smooth beep helper
function beep(freq, type, start, dur, vol, ctx, dest) {
  const o = ctx.createOscillator();
  const g = ctx.createGain();
  o.type = type;
  o.frequency.setValueAtTime(freq, start);
  g.gain.setValueAtTime(0, start);
  g.gain.linearRampToValueAtTime(vol, start + 0.01);
  g.gain.exponentialRampToValueAtTime(0.001, start + dur);
  o.connect(g); g.connect(dest);
  o.start(start); o.stop(start + dur);
}

// 🎵 Cheerful chime — sound ON confirm
function playChime() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime;
  [523, 659, 784, 1047].forEach((f, i) => beep(f, 'sine', t + i * 0.1, 0.3, 0.3, ctx, ctx.destination));
}

// 🎉 Winner fanfare — next player / done
function playWin() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime, d = ctx.destination;
  [392, 523, 659, 784, 1047].forEach((f, i) => beep(f, 'sine', t + i * 0.08, 0.25, 0.25, ctx, d));
  beep(1047, 'sine', t + 0.4, 0.5, 0.2, ctx, d);
}

// 🌀 Spin tick — wheel spinning
function playTick() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime;
  beep(800, 'square', t, 0.04, 0.15, ctx, ctx.destination);
}

// 💀 Loser buzz — punishment triggered
function playLoser() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime, d = ctx.destination;
  // Descending "wah wah wah" trombone
  const o = ctx.createOscillator();
  const g = ctx.createGain();
  o.type = 'sawtooth';
  o.frequency.setValueAtTime(300, t);
  o.frequency.linearRampToValueAtTime(200, t + 0.25);
  o.frequency.setValueAtTime(280, t + 0.3);
  o.frequency.linearRampToValueAtTime(180, t + 0.55);
  o.frequency.setValueAtTime(260, t + 0.6);
  o.frequency.linearRampToValueAtTime(150, t + 0.9);
  g.gain.setValueAtTime(0, t);
  g.gain.linearRampToValueAtTime(0.35, t + 0.02);
  g.gain.setValueAtTime(0.35, t + 0.22);
  g.gain.linearRampToValueAtTime(0, t + 0.28);
  g.gain.linearRampToValueAtTime(0.3, t + 0.32);
  g.gain.linearRampToValueAtTime(0, t + 0.58);
  g.gain.linearRampToValueAtTime(0.25, t + 0.62);
  g.gain.exponentialRampToValueAtTime(0.001, t + 0.95);
  o.connect(g); g.connect(d);
  o.start(t); o.stop(t + 1);
  // Low drum thud
  const n = ctx.createOscillator(), ng = ctx.createGain();
  n.type = 'sine'; n.frequency.setValueAtTime(80, t); n.frequency.exponentialRampToValueAtTime(30, t + 0.3);
  ng.gain.setValueAtTime(0.5, t); ng.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
  n.connect(ng); ng.connect(d); n.start(t); n.stop(t + 0.4);
}

// ❓ Card flip whoosh
function playFlip() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime, d = ctx.destination;
  const o = ctx.createOscillator(), g = ctx.createGain();
  o.type = 'sine';
  o.frequency.setValueAtTime(200, t);
  o.frequency.exponentialRampToValueAtTime(800, t + 0.15);
  g.gain.setValueAtTime(0.2, t);
  g.gain.exponentialRampToValueAtTime(0.001, t + 0.2);
  o.connect(g); g.connect(d); o.start(t); o.stop(t + 0.25);
}

// 🔔 Truth chime — gentle ascending
function playTruth() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime, d = ctx.destination;
  [440, 550, 660].forEach((f, i) => beep(f, 'sine', t + i * 0.1, 0.35, 0.2, ctx, d));
}

// 🔥 Dare buzz — edgy
function playDare() {
  if (!soundOn) return;
  const ctx = getCtx(), t = ctx.currentTime, d = ctx.destination;
  beep(150, 'sawtooth', t, 0.08, 0.3, ctx, d);
  beep(200, 'sawtooth', t + 0.1, 0.08, 0.3, ctx, d);
  beep(250, 'square', t + 0.2, 0.15, 0.25, ctx, d);
  beep(400, 'sine', t + 0.32, 0.2, 0.2, ctx, d);
}

